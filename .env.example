# GitHub OAuth (optional - enables "Login" button with device flow)
# Create an OAuth App at https://github.com/settings/developers
# Set "Device flow" enabled; no callback URL needed for device flow
VITE_GH_CLIENT_ID=
VITE_GH_OAUTH_PROXY=

# GitHub fine-grained PAT — for live stats on Home page (rate-limit uplift only)
# Without token: 60 req/hr (sufficient for low-traffic sites)
# With token:   5000 req/hr
# ⚠️  SECURITY: This token is bundled into the client JS and visible in DevTools.
#    Use a fine-grained PAT with NO repository permissions and NO OAuth scopes.
#    Create at: https://github.com/settings/personal-access-tokens/new
#    Set ALL permissions to "No access". Token is used only for rate-limit uplift.
VITE_GH_TOKEN=

# GitHub Pages base path (set automatically by deploy workflow)
# VITE_REPO_BASE=/ajch_cluade_architect/

# Google Analytics 4 — cookieless mode (Issue #14)
# Create property at analytics.google.com → copy Measurement ID (G-XXXXXXXXXX)
# No cookies set; storage: 'none' mode — no consent banner required
VITE_GA_MEASUREMENT_ID=

# Dual-channel subscribe (Issue #82) — Cloudflare Worker + public Gist stats
# Worker URL from `wrangler deploy` output (https://aarya-subscribe.*.workers.dev)
VITE_SUBSCRIBE_WORKER_URL=
# Public stats Gist ID — the Gist ID (not full URL) of aarya-stats.json
# Safe to bundle: public Gist, contains only aggregate counts (no PII)
VITE_STATS_GIST_ID=